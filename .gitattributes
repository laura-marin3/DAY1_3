# Détection automatique des fichiers texte
* text=auto

# Toujours en LF dans le dépôt
*.py text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Scripts Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Images et fichiers binaires
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary